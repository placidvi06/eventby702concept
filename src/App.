body {
  margin: 0;
  font-family: "Segoe UI", sans-serif;
  background: #0b0b0f;
  color: #f5f5f5;
}

main {
  max-width: 900px;
  margin: 0 auto;
  padding: 60px 20px;
  text-align: center;
}

h1 {
  font-size: 3rem;
  letter-spacing: 2px;
  color: gold;
}

h2 {
  font-weight: 300;
  color: #ddd;
}

p {
  color: #bbb;
  line-height: 1.6;
}

button {
  margin: 10px;
  padding: 12px 24px;
  border: none;
  cursor: pointer;
  font-weight: bold;
  border-radius: 30px;
  transition: 0.3s;
}

button:first-of-type {
  background: gold;
  color: black;
}

button:last-of-type {
  background: transparent;
  border: 1px solid gold;
  color: gold;
}

button:hover {
  transform: scale(1.05);
}

hr {
  margin: 40px 0;
  border: 0;
  border-top: 1px solid #222;
}

ul {
  list-style: none;
  padding: 0;
}

li {
  padding: 8px 0;
  color: #ccc;
}
